            "url": {
              "raw": "{{baseUrl}}/api/v1/groups/{{groupId}}/members",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "groups",
                "{{groupId}}",
                "members"
              ]
            },
            "description": "Use when you create a group without the second user. If the user is already a member, this returns 409."
          }
        }
