              "mode": "raw",
              "raw": "{\n  \"name\": \"Weekend Trip\",\n  \"ownerUserId\": \"{{ownerUserId}}\",\n  \"memberUserIds\": [\"{{secondUserId}}\"],\n  \"icon\": \"plane\",\n  \"color\": \"#4F46E5\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/groups",
